{
  "name": "@lucas8x/pdfy",
  "version": "0.4.0",
  "module": "index.ts",
  "description": "cli tool for converting and compressing a image folder into a single PDF file.",
  "type": "module",
  "private": false,
  "author": "Lucas8x",
  "license": "MIT",
  "bin": {
    "pdfy": "dist/index.js"
  },
  "files": [
    "dist/index.js"
  ],
  "scripts": {
    "build": "bun build ./src/index.ts --outdir ./dist --target=node",
    "build:prod": "bun build ./src/index.ts --outdir ./dist --production --target=node",
    "prepack": "bun run build:prod",
    "check": "ultracite check",
    "fix": "ultracite fix"
  },
  "dependencies": {
    "archiver": "^8.0.0",
    "bmp-js": "^0.1.0",
    "commander": "^15.0.0",
    "filesize": "^11.0.17",
    "p-limit": "^7.3.0",
    "pdfkit": "^0.18.0",
    "progress": "^2.0.3",
    "prompts": "^2.4.2",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15",
    "@types/archiver": "^8.0.0",
    "@types/progress": "^2.0.7",
    "@types/bmp-js": "^0.1.2",
    "@types/bun": "^1.3.13",
    "@types/pdfkit": "^0.17.6",
    "@types/prompts": "^2.4.9",
    "typescript": "^6.0.3",
    "ultracite": "7.7.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Lucas8x/pdfy.git"
  },
  "homepage": "https://github.com/Lucas8x/pdfy",
  "bugs": {
    "url": "https://github.com/Lucas8x/pdfy/issues"
  },
  "keywords": [
    "pdf",
    "cli",
    "images",
    "pdfy",
    "transform",
    "convert",
    "compress"
  ],
  "publishConfig": {
    "access": "public"
  }
}
